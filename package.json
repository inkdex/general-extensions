{
  "name": "general-extensions",
  "repositoryName": "General Extensions (0.9)",
  "description": "Paperback extensions for websites with unique, non-generic themes. Maintained by Inkdex.",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint --type-aware --fix",
    "lint:check": "oxlint --type-aware --deny-warnings",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "tsc": "tsc",
    "bundle": "paperback-cli bundle",
    "serve": "paperback-cli serve",
    "logcat": "paperback-cli logcat",
    "dev": "paperback-cli serve --watch",
    "test": "npm run tsc && npm run lint:check && npm run format:check && npm run bundle",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@paperback/toolchain": "^1.0.0-alpha.57",
    "@paperback/types": "^1.0.0-alpha.57",
    "@types/upng-js": "^2.1.5",
    "cheerio": "^1.1.2",
    "fastest-levenshtein": "^1.0.16",
    "husky": "^9.1.7",
    "jpeg-js": "^0.4.4",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.32.0",
    "oxlint-tsgolint": "^0.9.0",
    "stemmer": "^2.0.1",
    "typescript": "^5.9.3",
    "upng-js": "^2.1.0"
  }
}
